<!-- 首页 - 创建/加入共享 -->
<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 顶部标题 -->
  <view class="header">
    <text class="header-title">位置共享</text>
    <text class="header-subtitle">实时查看彼此的位置</text>
  </view>



  <!-- 主功能区 -->
  <view class="main-content">
    <!-- 创建房间 -->
    <view class="action-card" bindtap="onCreateRoom">
      <view class="action-icon create-icon">🔗</view>
      <view class="action-text">
        <text class="action-title">创建共享房间</text>
        <text class="action-desc">生成共享码，邀请对方加入</text>
      </view>
      <text class="action-arrow">›</text>
    </view>

    <!-- 加入房间 -->
    <view class="action-card" bindtap="onJoinRoom">
      <view class="action-icon join-icon">🔑</view>
      <view class="action-text">
        <text class="action-title">加入共享房间</text>
        <text class="action-desc">输入对方提供的共享码</text>
      </view>
      <text class="action-arrow">›</text>
    </view>
  </view>

  <!-- 共享码弹窗 (创建后显示) -->
  <view class="modal-overlay" wx:if="{{showShareCode}}">
    <view class="modal-box">
      <view class="modal-header">
        <text class="modal-title">共享房间已创建</text>
        <text class="modal-subtitle">将下方共享码发送给对方</text>
      </view>

      <view class="share-code-display">
        <view class="code-digits">
          <text class="code-digit" wx:for="{{shareCodeArray}}" wx:key="*this">{{item}}</text>
        </view>
        <button class="btn-copy" bindtap="onCopyCode">复制共享码</button>
      </view>

    

      <!-- 等待状态 -->
      <view class="waiting-status">
        <view class="loading-dots">
          <view class="dot"></view>
          <view class="dot"></view>
          <view class="dot"></view>
        </view>
        <text class="waiting-text">等待对方加入...</text>
      </view>

      <!-- 取消按钮 -->
      <button class="btn-cancel" bindtap="onCancelRoom">取消共享</button>
    </view>
  </view>

  <!-- Toast -->
  <view class="toast-overlay" wx:if="{{toast.show}}">
    <view class="toast-box">
      <text>{{toast.message}}</text>
    </view>
  </view>
</view>
