/** 地图页样式 */
.page {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.map {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100vh;
}

/* 顶部信息栏 */
.info-bar {
  position: absolute;
  top: 200rpx;
  left: 16px;
  right: 16px;
  z-index: 10;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-radius: 14px;
  padding: 10px 14px;
  display: flex;
  align-items: center;
  box-shadow: 0 2px 16px rgba(0, 0, 0, 0.12);
}

.info-bar-left {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 10px;
}

.partner-avatar {
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: 2px solid #fff;
  box-shadow: 0 2px 6px rgba(0, 0, 0, 0.15);
  flex-shrink: 0;
}

.partner-detail {
  flex: 1;
  min-width: 0;
}

.partner-name {
  font-size: 15px;
  font-weight: 600;
  color: #333;
  display: block;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.partner-status {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-top: 2px;
}

.status-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
}

.status-dot.online {
  background: #07c160;
  box-shadow: 0 0 6px rgba(7, 193, 96, 0.6);
}

.status-dot.offline {
  background: #ccc;
}

.status-text {
  font-size: 12px;
  color: #999;
}

.update-time {
  font-size: 11px;
  color: #bbb;
  margin-left: 2px;
}

.info-bar-right {
  flex-shrink: 0;
  padding-left: 12px;
}

.distance-text {
  font-size: 18px;
  font-weight: 700;
  color: var(--primary);
}

/* 自身位置指示 - 简约版 */
.self-indicator {
  position: absolute;
  bottom: 170px;
  right: 20px;
  z-index: 10;
  width: 28px;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.self-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: #409eff;
  border: 2.5px solid #fff;
  box-shadow: 0 0 0 3px rgba(64, 158, 255, 0.25), 0 2px 8px rgba(0,0,0,0.15);
  position: absolute;
  z-index: 2;
  animation: pulse-dot 2s ease-in-out infinite;
}

@keyframes pulse-dot {
  0%, 100% { box-shadow: 0 0 0 3px rgba(64, 158, 255, 0.25), 0 2px 8px rgba(0,0,0,0.15); }
  50% { box-shadow: 0 0 0 6px rgba(64, 158, 255, 0.12), 0 2px 8px rgba(0,0,0,0.15); }
}

.direction-line {
  position: absolute;
  top: -18px;
  width: 2.5px;
  height: 20px;
  background: #409eff;
  border-radius: 2px;
  transform-origin: bottom center;
  z-index: 1;
  transition: transform 0.3s ease;
}

.direction-line::after {
  content: '';
  position: absolute;
  top: -3px;
  left: 50%;
  transform: translateX(-50%);
  width: 0;
  height: 0;
  border-left: 4px solid transparent;
  border-right: 4px solid transparent;
  border-bottom: 6px solid #409eff;
}

.self-tag {
  position: absolute;
  bottom: -18px;
  font-size: 10px;
  font-weight: 500;
  color: #409eff;
  background: rgba(255,255,255,0.85);
  padding: 1px 6px;
  border-radius: 8px;
}

/* 网络状态提示 */
.status-overlay {
  position: absolute;
  top: 100px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  background: rgba(0, 0, 0, 0.75);
  backdrop-filter: blur(8px);
  border-radius: 24px;
  padding: 10px 20px;
}

.status-overlay-content {
  display: flex;
  align-items: center;
  gap: 8px;
}

.status-overlay .loading-dots {
  display: flex;
  gap: 3px;
}

.status-overlay .dot {
  width: 6px;
  height: 6px;
  background: #ffc300;
  border-radius: 50%;
  animation: bounce 1.4s infinite;
}

.status-overlay .dot:nth-child(2) {
  animation-delay: 0.2s;
}

.status-overlay .dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

.status-overlay-text {
  font-size: 13px;
  color: #fff;
}

/* 定位失败提示 */
.location-error {
  position: absolute;
  top: 100px;
  left: 24px;
  right: 24px;
  z-index: 20;
  background: rgba(250, 81, 81, 0.9);
  border-radius: 12px;
  padding: 14px 16px;
  display: flex;
  align-items: center;
  gap: 8px;
  flex-wrap: wrap;
}

.location-error-icon {
  font-size: 16px;
}

.location-error-text {
  flex: 1;
  font-size: 13px;
  color: #fff;
  min-width: 0;
}

.location-retry-btn {
  background: rgba(255, 255, 255, 0.2);
  border: 1px solid rgba(255, 255, 255, 0.3);
  border-radius: 14px;
  padding: 4px 14px;
  font-size: 12px;
  color: #fff;
  line-height: 1.5;
}

/* 对方位置未更新提示 */
.stale-notice {
  position: absolute;
  bottom: 120px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 16px;
  padding: 8px 16px;
}

.stale-notice text {
  font-size: 12px;
  color: #ffc300;
}

/* 对方详情 - 简约底部卡片 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.4);
  display: flex;
  align-items: flex-end;
  z-index: 50;
}

.modal-sheet {
  background: #fff;
  border-radius: 16px 16px 0 0;
  padding: 12px 24px 32px;
  padding-bottom: calc(32px + env(safe-area-inset-bottom));
  width: 100%;
  animation: sheet-up 0.25s ease-out;
}

@keyframes sheet-up {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.sheet-handle {
  width: 32px;
  height: 4px;
  border-radius: 2px;
  background: #ddd;
  margin: 0 auto 16px;
}

.sheet-header {
  display: flex;
  align-items: center;
  gap: 12px;
  margin-bottom: 20px;
}

.sheet-avatar {
  width: 44px;
  height: 44px;
  border-radius: 50%;
  border: 2px solid #f0f0f0;
  flex-shrink: 0;
}

.sheet-meta {
  flex: 1;
}

.sheet-name {
  font-size: 16px;
  font-weight: 600;
  color: #1a1a1a;
  display: block;
}

.sheet-online {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 12px;
  color: #999;
  margin-top: 2px;
}

.online-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: #07c160;
}

.online-dot.off {
  background: #ccc;
}

.sheet-stats {
  display: flex;
  justify-content: space-around;
  text-align: center;
  background: #f8f9fc;
  border-radius: 12px;
  padding: 16px 8px;
}

.stat-item {
  flex: 1;
}

.stat-value {
  display: block;
  font-size: 18px;
  font-weight: 700;
  color: #1a1a1a;
  line-height: 1.2;
}

.stat-unit {
  font-size: 12px;
  font-weight: 400;
  color: #999;
}

.stat-label {
  font-size: 11px;
  color: #aaa;
  margin-top: 2px;
  display: block;
}

/* 底部控制 */
.bottom-controls {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 10;
  display: flex;
  justify-content: space-between;
  align-items: flex-end;
  padding: 16px;
  padding-bottom: calc(16px + env(safe-area-inset-bottom));
  background: linear-gradient(0deg, rgba(0,0,0,0.05) 0%, transparent 80%);
  pointer-events: none;
}

.bottom-controls > view,
.bottom-controls > button {
  pointer-events: auto;
}

.control-group {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.control-btn {
  width: 40px;
  height: 40px;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  cursor: pointer;
}

.control-btn:active {
  transform: scale(0.92);
}

.control-btn text {
  font-size: 18px;
  color: #333;
  font-weight: 600;
}

.btn-end-share {
  background: var(--danger);
  color: #fff;
  border: none;
  border-radius: 25px;
  padding: 14px 28px;
  font-size: 15px;
  font-weight: 600;
  box-shadow: 0 4px 16px rgba(250, 81, 81, 0.4);
  line-height: 1.5;
}

.btn-end-share:active {
  transform: scale(0.95);
}
