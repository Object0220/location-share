/** ===== 加入页样式 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(170deg, #0f0f23 0%, #1a1a3e 40%, #16213e 70%, #0a1628 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 28px;
  position: relative;
  overflow: hidden;
}

/* ---- 背景装饰 ---- */
.bg-decoration {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
}

.bg-glow-1 {
  width: 280px;
  height: 280px;
  background: rgba(64, 158, 255, 0.1);
  top: -100px;
  left: -80px;
}

.bg-glow-2 {
  width: 220px;
  height: 220px;
  background: rgba(64, 158, 255, 0.07);
  bottom: 80px;
  right: -60px;
}

.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 40px 40px;
}

/* ---- 返回按钮 ---- */
.back-btn {
  position: absolute;
  top: 54px;
  left: 12px;
  z-index: 10;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(6px);
}

.back-icon {
  font-size: 26px;
  color: #fff;
  line-height: 1;
}

/* ---- 顶部区域 ---- */
.top-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100px;
  padding-bottom: 36px;
}

.avatar-circle {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  background: rgba(64, 158, 255, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  backdrop-filter: blur(8px);
}

.avatar-icon {
  font-size: 30px;
}

.page-title {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
  letter-spacing: 0.5px;
}

.page-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  line-height: 1.6;
  max-width: 280px;
}

/* ---- 输入卡片 ---- */
.input-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  padding: 24px 32px;
  width: 100%;
  max-width: 320px;
  text-align: center;
  backdrop-filter: blur(12px);
  margin-bottom: 28px;
}

.code-slots {
  display: flex;
  justify-content: center;
  gap: 12px;
}

.code-slot {
  width: 56px;
  height: 66px;
  background: rgba(255, 255, 255, 0.05);
  border: 1.5px solid rgba(255, 255, 255, 0.1);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.25s ease;
}

.code-slot.filled {
  background: rgba(64, 158, 255, 0.15);
  border-color: rgba(64, 158, 255, 0.4);
  box-shadow: 0 0 20px rgba(64, 158, 255, 0.08);
}

.code-slot.active {
  border-color: #409eff;
  box-shadow: 0 0 16px rgba(64, 158, 255, 0.2);
}

.slot-text {
  font-size: 28px;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1px;
}

.slot-cursor {
  position: absolute;
  bottom: 12px;
  width: 2px;
  height: 20px;
  background: #409eff;
  border-radius: 1px;
  animation: cursor-blink 1s step-end infinite;
}

@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.slot-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 14px;
}

/* ---- 数字键盘 ---- */
.keyboard-area {
  width: 100%;
  max-width: 300px;
}

.kbd-row {
  display: flex;
  justify-content: center;
  gap: 14px;
  margin-bottom: 10px;
}

.kbd-key {
  width: 76px;
  height: 50px;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 500;
  color: #fff;
  transition: background 0.15s;
}

.kbd-key:active {
  background: rgba(255, 255, 255, 0.14);
}

.kbd-empty {
  background: transparent;
  pointer-events: none;
}

.kbd-delete-icon {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
}

/* ---- 底部操作 ---- */
.bottom-actions {
  width: 100%;
  text-align: center;
  height: 28px;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 24px;
  margin-top: 8px;
  margin-bottom: 20px;
}

.clear-btn, .paste-btn {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.35);
  padding: 6px 12px;
}

/* ---- 内嵌加载 ---- */
.inline-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 14px 24px;
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 14px;
  backdrop-filter: blur(12px);
  width: 100%;
  max-width: 320px;
  margin-bottom: 40px;
  animation: fadeInUp 0.3s ease;
}

.loading-spinner {
  width: 20px;
  height: 20px;
  border: 2px solid rgba(255, 255, 255, 0.15);
  border-top-color: #409eff;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  flex-shrink: 0;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.6);
}

/* ---- 错误提示 ---- */
.error-toast {
  position: fixed;
  bottom: 160px;
  left: 28px;
  right: 28px;
  background: rgba(250, 81, 81, 0.88);
  backdrop-filter: blur(12px);
  border-radius: 14px;
  padding: 14px 20px;
  text-align: center;
  z-index: 40;
  animation: fadeInUp 0.3s ease;
}

.error-toast text {
  font-size: 14px;
  color: #fff;
  line-height: 1.5;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}
