<!-- 加入页 - 输入司机手机号后四位加入救援 -->
<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-glow bg-glow-1"></view>
    <view class="bg-glow bg-glow-2"></view>
    <view class="bg-grid"></view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="onBack">
    <text class="back-icon">‹</text>
  </view>

  <!-- 顶部 -->
  <view class="top-section">
    <view class="avatar-circle">
      <text class="avatar-icon">🔑</text>
    </view>
    <text class="page-title">加入救援</text>
    <text class="page-desc">输入拖车司机的手机号后四位即可加入</text>
  </view>

  <!-- 输入卡片 -->
  <view class="input-card">
    <view class="code-slots">
      <view
        class="code-slot {{item.filled ? 'filled' : ''}} {{item.active ? 'active' : ''}}"
        wx:for="{{codeSlots}}" wx:key="index"
        data-index="{{index}}" bindtap="onSlotTap"
      >
        <text class="slot-text">{{item.value}}</text>
        <view class="slot-cursor" wx:if="{{item.active && !item.filled}}"></view>
      </view>
    </view>
    <view class="slot-label">手机号后四位</view>
  </view>

  <!-- 数字键盘 -->
  <view class="keyboard-area">
    <view class="kbd-row">
      <view class="kbd-key" data-value="1" bindtap="onKeyPress">1</view>
      <view class="kbd-key" data-value="2" bindtap="onKeyPress">2</view>
      <view class="kbd-key" data-value="3" bindtap="onKeyPress">3</view>
    </view>
    <view class="kbd-row">
      <view class="kbd-key" data-value="4" bindtap="onKeyPress">4</view>
      <view class="kbd-key" data-value="5" bindtap="onKeyPress">5</view>
      <view class="kbd-key" data-value="6" bindtap="onKeyPress">6</view>
    </view>
    <view class="kbd-row">
      <view class="kbd-key" data-value="7" bindtap="onKeyPress">7</view>
      <view class="kbd-key" data-value="8" bindtap="onKeyPress">8</view>
      <view class="kbd-key" data-value="9" bindtap="onKeyPress">9</view>
    </view>
    <view class="kbd-row">
      <view class="kbd-key kbd-empty"></view>
      <view class="kbd-key" data-value="0" bindtap="onKeyPress">0</view>
      <view class="kbd-key kbd-delete" bindtap="onDelete">
        <text class="kbd-delete-icon">⌫</text>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-actions">
    <text class="clear-btn" bindtap="onClear" wx:if="{{codeLength > 0}}">清空</text>
    <text class="clear-btn" wx:if="{{codeLength == 0}}" style="visibility:hidden">清空</text>
    <text class="paste-btn" bindtap="onPaste" wx:if="{{!isScanning}}">从剪贴板粘贴</text>
  </view>

  <!-- 内嵌加载状态 -->
  <view class="inline-loading" wx:if="{{loading}}">
    <view class="loading-spinner"></view>
    <text class="loading-text">正在加入救援...</text>
  </view>

  <!-- 错误提示 -->
  <view class="error-toast" wx:if="{{errorMsg}}">
    <text>{{errorMsg}}</text>
  </view>
</view>
