/** ===== 等待页样式 ===== */
.page {
  min-height: 100vh;
  background: linear-gradient(170deg, #0f0f23 0%, #1a1a3e 40%, #16213e 70%, #0a1628 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 0 28px;
  position: relative;
  overflow: hidden;
}

/* ---- 背景装饰 ---- */
.bg-decoration {
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.bg-glow {
  position: absolute;
  border-radius: 50%;
  filter: blur(80px);
}

.bg-glow-1 {
  width: 280px;
  height: 280px;
  background: rgba(7, 193, 96, 0.12);
  top: -100px;
  right: -80px;
}

.bg-glow-2 {
  width: 220px;
  height: 220px;
  background: rgba(7, 193, 96, 0.08);
  bottom: 80px;
  left: -60px;
}

.bg-grid {
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
  background-size: 40px 40px;
}

/* ---- 返回按钮 ---- */
.back-btn {
  position: absolute;
  top: 54px;
  left: 12px;
  z-index: 10;
  width: 36px;
  height: 36px;
  border-radius: 10px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(6px);
}

.back-icon {
  font-size: 26px;
  color: #fff;
  line-height: 1;
}

/* ---- 顶部区域 ---- */
.top-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 100px;
  padding-bottom: 32px;
}

.avatar-circle {
  width: 64px;
  height: 64px;
  border-radius: 20px;
  background: rgba(7, 193, 96, 0.15);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16px;
  backdrop-filter: blur(8px);
}

.avatar-circle.success {
  background: rgba(7, 193, 96, 0.2);
  box-shadow: 0 0 30px rgba(7, 193, 96, 0.15);
}

.avatar-icon {
  font-size: 30px;
}

.page-title {
  font-size: 26px;
  font-weight: 700;
  color: #fff;
  margin-bottom: 8px;
  letter-spacing: 0.5px;
}

.page-desc {
  font-size: 14px;
  color: rgba(255, 255, 255, 0.5);
  text-align: center;
  line-height: 1.6;
  max-width: 280px;
}

/* ---- 输入卡片 ---- */
.input-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  padding: 24px 32px;
  width: 100%;
  max-width: 320px;
  text-align: center;
  backdrop-filter: blur(12px);
  margin-bottom: 28px;
}

.code-slots {
  display: flex;
  justify-content: center;
  gap: 12px;
}

.code-slot {
  width: 56px;
  height: 66px;
  background: rgba(255, 255, 255, 0.05);
  border: 1.5px solid rgba(255, 255, 255, 0.1);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  transition: all 0.25s ease;
}

.code-slot.filled {
  background: rgba(7, 193, 96, 0.15);
  border-color: rgba(7, 193, 96, 0.4);
  box-shadow: 0 0 20px rgba(7, 193, 96, 0.08);
}

.code-slot.static {
  background: linear-gradient(135deg, rgba(7, 193, 96, 0.18), rgba(7, 193, 96, 0.08));
  border-color: rgba(7, 193, 96, 0.35);
  box-shadow: 0 4px 20px rgba(7, 193, 96, 0.1);
}

.slot-text {
  font-size: 28px;
  font-weight: 800;
  color: #fff;
  letter-spacing: 1px;
}

.slot-cursor {
  position: absolute;
  bottom: 12px;
  width: 2px;
  height: 20px;
  background: #07c160;
  border-radius: 1px;
  animation: cursor-blink 1s step-end infinite;
}

@keyframes cursor-blink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

.slot-label {
  font-size: 12px;
  color: rgba(255, 255, 255, 0.35);
  margin-top: 14px;
}

/* ---- 展示卡片（等待态） ---- */
.code-card {
  background: rgba(255, 255, 255, 0.06);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 20px;
  padding: 28px 32px;
  width: 100%;
  max-width: 320px;
  text-align: center;
  backdrop-filter: blur(12px);
  margin-bottom: 24px;
}

/* ---- 数字键盘 ---- */
.keyboard-area {
  width: 100%;
  max-width: 300px;
}

.kbd-row {
  display: flex;
  justify-content: center;
  gap: 14px;
  margin-bottom: 10px;
}

.kbd-key {
  width: 76px;
  height: 50px;
  background: rgba(255, 255, 255, 0.07);
  border-radius: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22px;
  font-weight: 500;
  color: #fff;
  transition: background 0.15s;
}

.kbd-key:active {
  background: rgba(255, 255, 255, 0.14);
}

.kbd-empty {
  background: transparent;
  pointer-events: none;
}

.kbd-delete-icon {
  font-size: 20px;
  color: rgba(255, 255, 255, 0.5);
}

/* ---- 底部操作 ---- */
.bottom-actions {
  width: 100%;
  text-align: center;
  height: 28px;
  margin-bottom: 16px;
}

.clear-btn {
  font-size: 13px;
  color: rgba(255, 255, 255, 0.35);
  padding: 6px 16px;
}

/* ---- 创建按钮 ---- */
.btn-create {
  width: 100%;
  max-width: 320px;
  border: none;
  border-radius: 16px;
  padding: 16px 0;
  font-size: 16px;
  font-weight: 600;
  line-height: 1.5;
  color: rgba(255, 255, 255, 0.3);
  background: rgba(255, 255, 255, 0.06);
  transition: all 0.3s ease;
}

.btn-create.active {
  background: linear-gradient(135deg, #07c160, #05a34e);
  color: #fff;
  box-shadow: 0 6px 24px rgba(7, 193, 96, 0.3);
}

.btn-create.active:active {
  transform: scale(0.97);
  box-shadow: 0 3px 12px rgba(7, 193, 96, 0.2);
}

/* ---- 复制按钮 ---- */
.btn-copy {
  width: 100%;
  max-width: 320px;
  border: none;
  border-radius: 16px;
  padding: 16px 0;
  font-size: 16px;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  color: #fff;
  line-height: 1.5;
  transition: all 0.2s;
}

.btn-copy:active {
  background: rgba(255, 255, 255, 0.14);
}

.copy-icon {
  font-size: 18px;
}

/* ---- 等待动画 ---- */
.waiting-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  margin-top: 32px;
  margin-bottom: 32px;
  position: relative;
}

.pulse-ring {
  position: absolute;
  top: -8px;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid rgba(7, 193, 96, 0.3);
  animation: pulse-ring 2s ease-out infinite;
}

@keyframes pulse-ring {
  0% {
    transform: scale(0.8);
    opacity: 0.6;
  }
  100% {
    transform: scale(2.2);
    opacity: 0;
  }
}

.waiting-dots {
  display: flex;
  gap: 8px;
}

.wdot {
  width: 10px;
  height: 10px;
  background: #07c160;
  border-radius: 50%;
  animation: wdot-bounce 1.4s ease-in-out infinite;
}

.wdot:nth-child(2) {
  animation-delay: 0.2s;
}

.wdot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes wdot-bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.3;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.waiting-text {
  font-size: 15px;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 400;
}

/* ---- 取消按钮 ---- */
.btn-cancel {
  width: 100%;
  max-width: 320px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 16px;
  padding: 14px 0;
  font-size: 15px;
  color: rgba(255, 255, 255, 0.4);
  background: transparent;
  line-height: 1.5;
  transition: all 0.2s;
}

.btn-cancel:active {
  background: rgba(255, 255, 255, 0.05);
  border-color: rgba(255, 255, 255, 0.2);
}
