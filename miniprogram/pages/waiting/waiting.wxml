<!-- 等待页 - 创建房间后显示共享码，等待客户加入 -->
<view class="page">
  <!-- 背景装饰 -->
  <view class="bg-decoration">
    <view class="bg-circle bg-circle-1"></view>
    <view class="bg-circle bg-circle-2"></view>
  </view>

  <!-- 返回按钮 -->
  <view class="back-btn" bindtap="onBack">
    <text class="back-arrow">‹</text>
    <text class="back-text">返回</text>
  </view>

  <!-- 主内容 -->
  <view class="main-content">
    <!-- 标题 -->
    <view class="header">
      <text class="header-icon">🔗</text>
      <text class="header-title">救援房间已创建</text>
      <text class="header-subtitle">将下方共享码发送给客户即可加入</text>
    </view>

    <!-- 共享码卡片 -->
    <view class="code-card">
      <view class="code-digits">
        <text class="code-digit" wx:for="{{shareCodeArray}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <!-- 操作 -->
    <view class="actions">
      <button class="btn-copy" bindtap="onCopyCode">
        <text class="btn-icon">📋</text>
        <text>复制共享码</text>
      </button>
    </view>

    <!-- 等待状态 -->
    <view class="waiting-section">
      <view class="loading-dots">
        <view class="dot"></view>
        <view class="dot"></view>
        <view class="dot"></view>
      </view>
      <text class="waiting-text">等待客户加入...</text>
    </view>

    <!-- 取消按钮 -->
    <button class="btn-cancel" bindtap="onCancelRoom">取消救援</button>
  </view>
</view>
